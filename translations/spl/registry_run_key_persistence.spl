# Rule: Registry Run Key Persistence
index=* sourcetype="XmlWinEventLog:Microsoft-Windows-Sysmon/Operational" EventCode=13
(TargetObject="*\\Software\\Microsoft\\Windows\\CurrentVersion\\Run*" OR TargetObject="*\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce*")
NOT (Details="*Microsoft\\OneDrive*" OR Details="*Teams.exe*")
| table _time host User Image TargetObject Details
